# ============================================================
# ENVIRONMENT VARIABLES — ALL OPTIONAL
#
# These are ONLY needed for deploying to real testnets or
# running the Certora cloud prover. The project runs fully
# locally without any of these variables set:
#
#   npx hardhat compile     ← works without .env
#   npx hardhat test        ← works without .env
#   npx hardhat run ...     ← works without .env (uses local network)
#   mvn clean compile       ← works without .env
#
# To use these, copy this file to .env and fill in the values:
#   cp .env.example .env
# ============================================================

# --- Sepolia Testnet Deployment (optional) ---
# Only needed if you run: npx hardhat run scripts/deploy.js --network sepolia
# Get a free RPC URL from https://www.alchemy.com or https://www.infura.io
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
SEPOLIA_PRIVATE_KEY=your_deployer_private_key_without_0x_prefix

# --- Certora Formal Verification (optional) ---
# Only needed if you run: certoraRun contracts/... --verify ...
# Sign up for a free academic key at https://www.certora.com
CERTORAKEY=your_certora_api_key
